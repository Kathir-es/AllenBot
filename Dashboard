    private interface LabelWire { void wire(JLabel l); }
    private JPanel buildStatCard(String title, String initialVal, LabelWire wire) {
        JPanel card = new JPanel(new GridLayout(2, 1, 0, 4));
        card.setBackground(new Color(22, 24, 44));
        card.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(new Color(50, 55, 90), 1),
            BorderFactory.createEmptyBorder(8, 12, 8, 12)
        ));
        JLabel t = new JLabel(title);
        t.setFont(new Font("Monospaced", Font.PLAIN, 10));
        t.setForeground(new Color(90, 100, 140));
        JLabel v = new JLabel(initialVal);
        v.setFont(new Font("Monospaced", Font.BOLD, 28));
        v.setForeground(Color.WHITE);
        wire.wire(v);
        card.add(t);
        card.add(v);
        return card;
    }

