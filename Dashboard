    // --- Demo sequence: {targetValue, holdMs, label} ---
    private static final Object[][] DEMO_STEPS = {
        {   0,  800, "startup – sensor at zero"         },
        { 300,  900, "idle – room air, no gas"          },
        { 750, 1000, "normal – background LPG trace"    },
        {1200, 1000, "slight rise – ventilate area"     },
        {1800, 1200, "approaching warning threshold..."  },
        {2100, 1500, "WARNING zone entered"              },
        {2600, 1200, "WARNING – gas level climbing"     },
        {3100, 1800, "DANGER – leak detected!"          },
        {3800, 1500, "CRITICAL – evacuate now!"         },
        {4095, 1000, "SENSOR MAXED OUT"                 },
        {3200,  800, "leak source partially sealed"     },
        {2400, 1000, "dropping back through warning"    },
        {1500, 1000, "recovering..."                    },
        { 600, 1200, "returning to safe levels"         },
        { 100,  800, "system secure – standby"          },
    };

    private int  demoStepIndex = 0;
    private int  demoFromValue = 0;
    private int  demoToValue   = 0;
    private int  demoAnimTick  = 0;
    private int  demoAnimTotal = 0;
    private int  demoHoldTicks = 0;
    private boolean demoHolding  = false;
    private boolean demoRunning  = false;

    // =========================================================
    public tut1() {
        setTitle("ALLEN NODE – LPG Integrity System");
