        add(buildHeader(),      BorderLayout.NORTH);
        add(buildCenter(),      BorderLayout.CENTER);
        add(buildBottomPanel(), BorderLayout.SOUTH);

        setLocationRelativeTo(null);
        updateUI(0);

        // Auto-start demo after 1 second
        Timer startDelay = new Timer(1000, e -> startDemo());
        startDelay.setRepeats(false);
        startDelay.start();
    }

    // =========================================================
    //  DEMO ENGINE
    // =========================================================
    private void startDemo() {
        demoRunning   = true;
        demoStepIndex = 0;
        demoHolding   = false;
        peakValue     = 0;
        breachCount   = 0;
        wasInDanger   = false;
        peakValueLabel.setText("0");
        breachCountLabel.setText("0");
        loadNextStep();

        demoTimer = new Timer(16, e -> tickDemo());
        demoTimer.start();
        simSlider.setEnabled(false);
    }

    private void stopDemo() {
        demoRunning = false;
        if (demoTimer != null) demoTimer.stop();
        demoStepLabel.setText("Manual mode – drag slider below");
        simSlider.setEnabled(true);
    }

    private void loadNextStep() {
        if (demoStepIndex >= DEMO_STEPS.length) {
            demoStepIndex = 0;
        }
        Object[] step  = DEMO_STEPS[demoStepIndex];
        demoToValue    = (int)    step[0];
        int holdMs     = (int)    step[1];
        String label   = (String) step[2];

        demoFromValue  = currentValue;
        demoAnimTotal  = Math.max(1, Math.abs(demoToValue - demoFromValue) / 8);
        demoAnimTick   = 0;
        demoHoldTicks  = holdMs / 16;
        demoHolding    = false;

        demoStepLabel.setText("Demo step " + (demoStepIndex + 1) + "/" + DEMO_STEPS.length + ":  " + label);
    }

    private void tickDemo() {
        if (!demoRunning) return;

        if (!demoHolding) {
            demoAnimTick++;
            double progress = Math.min(1.0, (double) demoAnimTick / demoAnimTotal);
            // Ease in-out cubic
            double eased = progress < 0.5
                ? 2 * progress * progress
                : 1 - Math.pow(-2 * progress + 2, 2) / 2;
            int val = (int)(demoFromValue + eased * (demoToValue - demoFromValue));
            simSlider.setValue(val);
            updateUI(val);

            if (demoAnimTick >= demoAnimTotal) {
                demoHolding   = true;
                demoHoldTicks = ((int) DEMO_STEPS[demoStepIndex][1]) / 16;
            }
        } else {
            demoHoldTicks--;
            if (demoHoldTicks <= 0) {
                demoStepIndex++;
                loadNextStep();
            }
        }
    }

