    private JButton makeButton(String text, Color bg) {
        JButton b = new JButton(text);
        b.setFont(new Font("Monospaced", Font.BOLD, 10));
        b.setBackground(bg);
        b.setForeground(Color.WHITE);
        b.setFocusPainted(false);
        b.setBorder(BorderFactory.createCompoundBorder(
            BorderFactory.createLineBorder(bg.brighter(), 1),
            BorderFactory.createEmptyBorder(4, 10, 4, 10)
        ));
        b.setCursor(Cursor.getPredefinedCursor(Cursor.HAND_CURSOR));
        return b;
    }

    // =========================================================
    //  UPDATE LOGIC
    // =========================================================
    private void updateUI(int value) {
        currentValue = value;

        if (value > peakValue) {
            peakValue = value;
            peakValueLabel.setText(String.valueOf(peakValue));
        }

        boolean inDanger = value >= 3000;
        if (inDanger && !wasInDanger) {
            breachCount++;
            breachCountLabel.setText(String.valueOf(breachCount));
        }
        wasInDanger = inDanger;

        gasValueLabel.setText(String.valueOf(value));
        gasGauge.setValue(value);

        String zone;
        Color zoneColor;
        if (value >= 3000) {
            zone      = "DANGER";
            zoneColor = new Color(231, 76, 60);
            statusIcon.setText("🚨");
            statusText.setText("DANGER: LPG LEAK DETECTED!");
            statusPanel.setBackground(new Color(180, 30, 20));
            gasGauge.setForeground(Color.RED);
            gasValueLabel.setForeground(new Color(255, 80, 80));
        } else if (value >= 2000) {
            zone      = "WARNING";
            zoneColor = new Color(241, 196, 15);
            statusIcon.setText("⚠️");
            statusText.setText("WARNING: ELEVATED GAS LEVEL");
            statusPanel.setBackground(new Color(180, 140, 10));
            gasGauge.setForeground(Color.ORANGE);
            gasValueLabel.setForeground(new Color(241, 196, 15));
        } else {
            zone      = "SAFE";
            zoneColor = new Color(39, 174, 96);
            statusIcon.setText("✅");
            statusText.setText("SYSTEM SECURE");
            statusPanel.setBackground(new Color(30, 140, 80));
            gasGauge.setForeground(new Color(39, 174, 96));
            gasValueLabel.setForeground(new Color(80, 220, 140));
        }

        colorIndicator.setZone(zone, zoneColor);
        potPanel.update(value, zone, zoneColor);
        repaint();
    }

    // =========================================================
    //  LPG COLOR INDICATOR
    // =========================================================
    static class LPGColorIndicator extends JPanel {
        private Color  lampColor = new Color(39, 174, 96);
        private String zoneLabel = "SAFE";
        private float  glowAlpha = 0.4f;

        LPGColorIndicator() {
            setOpaque(false);
            new Timer(60, e -> {
                glowAlpha = (float)(0.25 + 0.25 * Math.sin(System.currentTimeMillis() / 350.0));
                repaint();
            }).start();
        }

        void setZone(String zone, Color color) {
            zoneLabel = zone; lampColor = color; repaint();
        }

        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            int w = getWidth(), h = getHeight();
            int r = Math.min(w, h) - 16;
            int x = (w - r) / 2, y = (h - r) / 2;
            g2.setColor(new Color(lampColor.getRed(), lampColor.getGreen(), lampColor.getBlue(),
                                  (int)(glowAlpha * 180)));
            g2.fillOval(x - 8, y - 8, r + 16, r + 16);
            g2.setColor(lampColor);
            g2.fillOval(x, y, r, r);
            g2.setColor(new Color(255, 255, 255, 60));
            g2.fillOval(x + r/5, y + r/8, r/2, r/3);
            g2.setColor(new Color(0, 0, 0, 80));
            g2.setStroke(new BasicStroke(2));
            g2.drawOval(x, y, r, r);
            g2.setFont(new Font("Monospaced", Font.BOLD, 9));
            g2.setColor(lampColor.brighter());
            FontMetrics fm = g2.getFontMetrics();
            g2.drawString(zoneLabel, (w - fm.stringWidth(zoneLabel)) / 2, y + r + 12);
            g2.dispose();
        }
    }

    // =========================================================
    //  POTENTIOMETER PANEL
    // =========================================================
    static class PotentiometerPanel extends JPanel {
        private int    value     = 0;
        private String zone      = "SAFE";
        private Color  zoneColor = new Color(39, 174, 96);
        private double angle     = 0;

        PotentiometerPanel() {
            setOpaque(false);
            setBorder(BorderFactory.createCompoundBorder(
                BorderFactory.createLineBorder(new Color(50, 55, 90), 1),
                BorderFactory.createEmptyBorder(8, 12, 8, 12)
            ));
        }

        void update(int v, String z, Color c) {
            value = v; zone = z; zoneColor = c;
            angle = Math.toRadians(-135 + (270.0 * v / 4095.0));
            repaint();
        }

        @Override
        protected void paintComponent(Graphics g) {
            super.paintComponent(g);
            Graphics2D g2 = (Graphics2D) g.create();
            g2.setRenderingHint(RenderingHints.KEY_ANTIALIASING, RenderingHints.VALUE_ANTIALIAS_ON);
            int w = getWidth(), h = getHeight();
            g2.setFont(new Font("Monospaced", Font.BOLD, 10));
            g2.setColor(new Color(90, 100, 140));
            g2.drawString("POTENTIOMETER STATUS", 0, 12);
            int knobSize = Math.min(h - 28, 70);
            int kx = 8, ky = (h - knobSize) / 2 + 6;
            g2.setColor(new Color(40, 44, 70));
            g2.setStroke(new BasicStroke(5, BasicStroke.CAP_ROUND, BasicStroke.JOIN_ROUND));
            g2.drawArc(kx + 3, ky + 3, knobSize - 6, knobSize - 6, 225, -270);
            g2.setColor(zoneColor);
            int sweep = (int)(270.0 * value / 4095.0);
            g2.drawArc(kx + 3, ky + 3, knobSize - 6, knobSize - 6, 225, -sweep);
            g2.setColor(new Color(35, 38, 62));
            g2.fillOval(kx + 8, ky + 8, knobSize - 16, knobSize - 16);
            g2.setColor(new Color(60, 65, 100));
            g2.setStroke(new BasicStroke(1.5f));
            g2.drawOval(kx + 8, ky + 8, knobSize - 16, knobSize - 16);
            int cx = kx + knobSize / 2, cy = ky + knobSize / 2;
            int pLen = knobSize / 2 - 12;
            int px = (int)(cx + pLen * Math.cos(angle));
            int py = (int)(cy + pLen * Math.sin(angle));
            g2.setColor(zoneColor);
            g2.setStroke(new BasicStroke(2.5f, BasicStroke.CAP_ROUND, BasicStroke.JOIN_ROUND));
            g2.drawLine(cx, cy, px, py);
            g2.setColor(zoneColor.brighter());
            g2.fillOval(cx - 4, cy - 4, 8, 8);
            int tx = kx + knobSize + 18, ty = ky + 14;
            g2.setFont(new Font("Monospaced", Font.PLAIN, 10));
            g2.setColor(new Color(90, 100, 140));
            g2.drawString("RAW ADC VALUE", tx, ty);
            g2.setFont(new Font("Monospaced", Font.BOLD, 26));
            g2.setColor(zoneColor);
            g2.drawString(String.valueOf(value), tx, ty + 28);
            int pct = (int)(100.0 * value / 4095);
            g2.setFont(new Font("Monospaced", Font.PLAIN, 11));
            g2.setColor(new Color(150, 160, 200));
            g2.drawString(pct + "%  of max range", tx, ty + 46);
            g2.setColor(new Color(zoneColor.getRed(), zoneColor.getGreen(), zoneColor.getBlue(), 40));
            g2.fillRoundRect(tx, ty + 52, 100, 20, 6, 6);
            g2.setColor(zoneColor);
            g2.setFont(new Font("Monospaced", Font.BOLD, 10));
            g2.drawString("ZONE: " + zone, tx + 6, ty + 66);
            g2.dispose();
        }
    }

